        }
        lines {
          text: "        loadedImages.push(img);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        img.onload = () => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "           loadedCount++;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "           // Draw frame 0 as soon as it loads to prevent empty canvas"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "           if (i === 0) renderFrame(0, loadedImages);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    setImages(loadedImages);"
