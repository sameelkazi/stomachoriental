        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const handleResize = () => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      renderFrame(Math.round(frameIndex.get()), loadedImages);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
