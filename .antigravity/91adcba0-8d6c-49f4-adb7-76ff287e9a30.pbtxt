    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Search, User, Menu, X, Star, Clock, Calendar, Play, ChevronLeft, ChevronRight } from \'lucide-react\';\n\nexport default function Landing() {\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n\n  const navLinks = [\n    { name: \"Movies\", delay: \"100ms\" },\n    { name: \"TV Series\", delay: \"150ms\" },\n    { name: \"Editor\'s Pick\", delay: \"200ms\" },\n    { name: \"Interviews\", delay: \"250ms\" },\n    { name: \"User Reviews\", delay: \"300ms\" }\n  ];\n\n  return (\n    <div className=\"relative w-full h-screen overflow-hidden bg-black text-white selection:bg-white/30 font-[\'Inter\']\">\n      {/* Background Video */}\n      <video\n        autoPlay\n        loop\n        muted\n        playsInline\n        className=\"fixed inset-0 w-full h-full object-cover z-0\"\n        src=\"https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260406_094145_4a271a6c-3869-4f1c-8aa7-aeb0cb227994.mp4\"\n      ></video>\n\n      {/* Bottom Blur Overlay */}\n      <div \n        className=\"fixed inset-0 z-10 pointer-events-none backdrop-blur-xl\"\n        style={{\n          maskImage: \'linear-gradient(to top, black 0%, transparent 45%)\',\n          WebkitMaskImage: \'linear-gradient(to top, black 0%, transparent 45%)\'\n        }}\n      ></div>\n\n      {/* Content Wrapper */}\n      <div className=\"relative z-50 flex flex-col h-full w-full\">\n        \n        {/* Navbar */}\n        <header className=\"relative flex justify-between items-center px-4 sm:px-6 md:px-12 py-4 md:py-6\">\n          {/* Logo */}\n          <div \n            className=\"text-xl md:text-2xl font-bold tracking-widest uppercase h-8 md:h-10 flex items-center animate-blur-fade-up\"\n            style={{ animationDelay: \'0ms\' }}\n          >\n            Cinematic\n          </div>\n\n          {/* Desktop Nav */}\n          <nav className=\"hidden lg:flex items-center gap-8\">\n            {navLinks.map((link, idx) => (\n              <a \n                key={idx} \n                href=\"#\" \n                className=\"text-sm font-medium hover:text-gray-300 transition-colors animate-blur-fade-up\"\n                style={{ animationDelay: link.delay }}\n              >\n                {link.name}\n              </a>\n            ))}\n          </nav>\n\n          {/* Right Actions */}\n          <div className=\"flex items-center gap-3 md:gap-4\">\n            <button \n              className=\"hidden sm:flex items-center gap-2 rounded-full liquid-glass px-4 md:px-6 py-2 text-sm font-medium hover:bg-white/10 transition-colors animate-blur-fade-up\"\n              style={{ animationDelay: \'350ms\' }}\n            >\n              <Search size={18} />\n              <span>Search</span>\n            </button>\n            <button \n              className=\"hidden sm:flex items-center justify-center w-10 h-10 rounded-full liquid-glass hover:bg-white/10 transition-colors animate-blur-fade-up text-white/90\"\n              style={{ animationDelay: \'400ms\' }}\n            >\n              <User size={18} />\n            </button>\n\n            {/* Mobile Menu Toggle */}\n            <button \n              onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n              className=\"lg:hidden flex items-center justify-center w-10 h-10 rounded-full liquid-glass hover:bg-white/10 transition-colors animate-blur-fade-up relative z-50\"\n              style={{ animationDelay: \'350ms\' }}\n            >\n              <div className=\"relative w-full h-full flex items-center justify-center\">\n                <Menu \n                  size={18} \n                  className={`absolute transition-all duration-500 ease-out ${\n                    isMobileMenuOpen ? \'rotate-180 opacity-0 scale-50\' : \'rotate-0 opacity-100 scale-100\'\n                  }`} \n                />\n                <X \n                  size={18} \n                  className={`absolute transition-all duration-500 ease-out ${\n                    isMobileMenuOpen ? \'rotate-0 opacity-100 scale-100\' : \'-rotate-180 opacity-0 scale-50\'\n                  }`} \n                />\n              </div>\n            </button>\n          </div>\n        </header>\n\n        {/* Mobile Menu Overlay */}\n        <div \n          className={`lg:hidden absolute top-[72px] left-4 right-4 z-40 bg-gray-900/95 backdrop-blur-lg border-t border-b border-gray-800 shadow-2xl rounded-2xl overflow-hidden transition-all duration-500 ease-out transform origin-top ${\n            isMobileMenuOpen ? \'translate-y-0 opacity-100\' : \'-translate-y-4 opacity-0 pointer-events-none\'\n          }`}\n        >\n          <div className=\"flex flex-col p-2\">\n            {navLinks.map((link, idx) => (\n               <a \n                 key={idx} \n                 href=\"#\" \n                 className={`py-3 px-3 rounded-lg hover:bg-gray-800/50 text-base font-medium transition-all duration-500 text-gray-200 hover:text-white flex items-center w-full`}\n                 style={{ \n                   transitionDelay: isMobileMenuOpen ? `${(idx+1)*50}ms` : \'0ms\',\n                   transform: isMobileMenuOpen ? \'translateX(0)\' : \'translateX(-20px)\',\n                   opacity: isMobileMenuOpen ? 1 : 0\n                 }}\n               >\n                 {link.name}\n               </a>\n            ))}\n            \n            <div className=\"sm:hidden mt-2 pt-4 pb-2 px-2 border-t border-gray-800 flex gap-3\">\n              <button className=\"flex-1 flex justify-center items-center gap-2 rounded-full liquid-glass px-4 py-3 text-sm font-medium hover:bg-white/10 transition-colors\">\n                <Search size={18} />\n                <span>Search</span>\n              </button>\n              <button className=\"flex items-center justify-center w-12 h-12 rounded-full liquid-glass hover:bg-white/10 transition-colors shrink-0\">\n                <User size={18} />\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Hero Bottom Content */}\n        <div className=\"flex-1 flex flex-col justify-end px-4 sm:px-6 md:px-12 pb-8 md:pb-16 pointer-events-none z-10\">\n          <div className=\"flex flex-col md:flex-row items-start md:items-end gap-8 w-full pointer-events-auto\">\n            \n            {/* Left Side */}\n            <div className=\"flex-1 w-full text-left\">\n              \n              {/* Metadata */}\n              <div \n                className=\"flex flex-wrap items-center gap-3 sm:gap-6 mb-6 md:mb-8 text-xs sm:text-sm text-white/90 animate-blur-fade-up\"\n                style={{ animationDelay: \'300ms\' }}\n              >\n                <div className=\"flex items-center gap-1.5 font-medium\">\n                  <Star size={16} className=\"fill-white sm:w-5 sm:h-5 text-white\" />\n                  <span>8.7/10 IMDB</span>\n                </div>\n                <div className=\"flex items-center gap-1.5\">\n                  <Clock size={16} className=\"text-white\" />\n                  <span>132 min</span>\n                </div>\n                <div className=\"flex items-center gap-1.5\">\n                  <Calendar size={16} className=\"text-white\" />\n                  <span>April, 2025</span>\n                </div>\n              </div>\n\n              {/* Title */}\n              <h1 \n                className=\"text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-normal tracking-[-0.04em] mb-4 md:mb-6 animate-blur-fade-up leading-tight text-white\"\n                style={{ animationDelay: \'400ms\' }}\n              >\n                Step Through.<br/>Work Smarter.\n              </h1>\n\n              {/* Description */}\n              <p \n                className=\"text-base sm:text-lg md:text-xl text-gray-400 mb-6 md:mb-12 max-w-2xl animate-blur-fade-up font-light leading-relaxed\"\n                style={{ animationDelay: \'500ms\' }}\n              >\n                A voyage through forgotten realms, where past and future intertwine.\n              </p>\n\n              {/* CTA Buttons */}\n              <div className=\"flex flex-wrap items-center gap-3 sm:gap-4\">\n                <button \n                  className=\"flex items-center justify-center gap-2 bg-white text-black rounded-full font-medium px-6 sm:px-8 py-2.5 sm:py-3 hover:bg-gray-200 transition-colors animate-blur-fade-up\"\n                  style={{ animationDelay: \'600ms\' }}\n                >\n                  <Play size={18} className=\"fill-black\" />\n                  <span>Watch Now</span>\n                </button>\n                <button \n                  className=\"rounded-full font-medium liquid-glass px-6 sm:px-8 py-2.5 sm:py-3 hover:bg-white/10 transition-colors animate-blur-fade-up\"\n                  style={{ animationDelay: \'700ms\' }}\n                >\n                  Learn More\n                </button>\n              </div>\n\n            </div>\n\n            {/* Right Side (Arrows) */}\n            <div className=\"flex items-center gap-3 w-fit\">\n              <button \n                className=\"rounded-full liquid-glass px-4 sm:px-6 py-2.5 sm:py-3 hover:bg-white/10 transition-colors animate-blur-fade-up flex justify-center items-center backdrop-blur-md\"\n                style={{ animationDelay: \'800ms\' }}\n              >\n                <ChevronLeft size={20} />\n              </button>\n              <button \n                className=\"rounded-full liquid-glass px-4 sm:px-6 py-2.5 sm:py-3 hover:bg-white/10 transition-colors animate-blur-fade-up flex justify-center items-center backdrop-blur-md\"\n                style={{ animationDelay: \'900ms\' }}\n              >\n                <ChevronRight size={20} />\n              </button>\n            </div>\n\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}"
    }
