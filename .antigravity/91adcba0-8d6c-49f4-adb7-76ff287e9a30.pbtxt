        }
        lines {
          text: "  const renderFrame = (index: number, imgs = images) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!imgs[index] || !canvasRef.current) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const canvas = canvasRef.current;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const ctx = canvas.getContext(\'2d\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!ctx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const img = imgs[index];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Set actual canvas resolution to window dimensions"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    canvas.width = window.innerWidth;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    canvas.height = window.innerHeight;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Object-cover logic"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const hRatio = canvas.width / img.width;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const vRatio = canvas.height / img.height;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const ratio = Math.max(hRatio, vRatio);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const centerShift_x = (canvas.width - img.width * ratio) / 2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const centerShift_y = (canvas.height - img.height * ratio) / 2;  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.clearRect(0, 0, canvas.width, canvas.height);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.drawImage(img, 0, 0, img.width, img.height,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  centerShift_x, centerShift_y, img.width * ratio, img.height * ratio);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
